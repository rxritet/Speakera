rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function duelDoc(duelId) {
      return get(/databases/$(database)/documents/duels/$(duelId));
    }

    function isDuelParticipant(duelId) {
      return signedIn() && request.auth.uid in duelDoc(duelId).data.participantIds;
    }

    function isOpenDuel(duelId) {
      return duelDoc(duelId).data.status == 'open';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId);

      match /badges/{badgeId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }

      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }

      match /xp/{docId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }

      match /weekStats/{weekId} {
        allow read, write: if isOwner(userId);
      }

      match /achievements/{achievementId} {
        allow read, write: if isOwner(userId);
      }

      match /stats/{statId} {
        allow read, write: if isOwner(userId);
      }

      match /friends/{friendId} {
        allow read, write: if isOwner(userId);
      }

      match /friendRequests/{requestId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if signedIn() && request.resource.data.fromUserId == request.auth.uid;
      }

      match /boosters/{boosterId} {
        allow read, write: if isOwner(userId);
      }

      match /currency/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /avatars/{avatarId} {
        allow read, write: if isOwner(userId);
      }

      match /inventory/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /quests/{dateKey} {
        allow read, write: if isOwner(userId);

        match /daily/{questId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /eventRewards/{rewardId} {
        allow read, write: if isOwner(userId);
      }

      match /events/{eventId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /duels/{duelId} {
      allow read: if signedIn() && (isDuelParticipant(duelId) || isOpenDuel(duelId));
      allow create: if signedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update: if isDuelParticipant(duelId);
      allow delete: if signedIn() && request.auth.uid == resource.data.creatorId;

      match /participants/{participantId} {
        allow read: if signedIn() && (isDuelParticipant(duelId) || isOpenDuel(duelId));
        allow write: if signedIn() &&
          (request.auth.uid == participantId || isDuelParticipant(duelId));
      }

      match /checkins/{checkinId} {
        allow read: if isDuelParticipant(duelId);
        allow create: if isDuelParticipant(duelId) &&
          request.auth.uid == request.resource.data.userId;
        allow update, delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isDuelParticipant(duelId);
        allow create: if isDuelParticipant(duelId) &&
          request.auth.uid == request.resource.data.senderId;
        allow update, delete: if false;
      }
    }

    match /invites/{inviteCode} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update: if signedIn();
      allow delete: if signedIn() && request.auth.uid == resource.data.creatorId;
    }

    match /shop/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /seasons/{seasonId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
