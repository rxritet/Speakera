rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId);

      match /badges/{badgeId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }

      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }

      match /xp/{docId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }

      match /weekStats/{weekId} {
        allow read, write: if isOwner(userId);
      }

      match /achievements/{achievementId} {
        allow read, write: if isOwner(userId);
      }

      match /stats/{statId} {
        allow read, write: if isOwner(userId);
      }

      match /friends/{friendId} {
        allow read, write: if isOwner(userId);
      }

      match /friendRequests/{requestId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if signedIn() && request.resource.data.fromUserId == request.auth.uid;
      }

      match /boosters/{boosterId} {
        allow read, write: if isOwner(userId);
      }

      match /currency/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /avatars/{avatarId} {
        allow read, write: if isOwner(userId);
      }

      match /inventory/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /quests/{dateKey} {
        allow read, write: if isOwner(userId);

        match /daily/{questId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /eventRewards/{rewardId} {
        allow read, write: if isOwner(userId);
      }

      match /events/{eventId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /duels/{duelId} {
      function isParticipant() {
        return signedIn() && request.auth.uid in resource.data.participantIds;
      }

      function isOpenLobby() {
        return resource.data.status == 'open';
      }

      function canJoinOpenDuel() {
        return signedIn() &&
          resource.data.status == 'open' &&
          !(request.auth.uid in resource.data.participantIds) &&
          request.auth.uid in request.resource.data.participantIds &&
          request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1 &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'participantIds',
            'updatedAt',
          ]);
      }

      allow read: if signedIn() && (isParticipant() || isOpenLobby());
      allow create: if signedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update: if isParticipant() || canJoinOpenDuel();
      allow delete: if signedIn() && request.auth.uid == resource.data.creatorId;

      match /participants/{participantId} {
        allow read: if signedIn() && (isParticipant() || isOpenLobby());
        allow write: if signedIn() &&
          (request.auth.uid == participantId || isParticipant());
      }

      match /checkins/{checkinId} {
        allow read: if isParticipant();
        allow create: if isParticipant() &&
          request.auth.uid == request.resource.data.userId;
        allow update, delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipant() &&
          request.auth.uid == request.resource.data.senderId;
        allow update, delete: if false;
      }
    }

    match /invites/{inviteCode} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update: if signedIn();
      allow delete: if signedIn() && request.auth.uid == resource.data.creatorId;
    }

    match /shop/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /seasons/{seasonId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
